# ====================================
# PageLM Production Configuration
# Ollama-Only Deployment
# ====================================

# Server Configuration
HOST=0.0.0.0
PORT=5000
NODE_ENV=production

# Backend URL (update with your production domain)
VITE_BACKEND_URL=http://localhost:5000

# Frontend URL (update with your production domain)
VITE_FRONTEND_URL=http://localhost:5173

# Request Timeout (milliseconds)
VITE_TIMEOUT=90000

# ====================================
# Ollama Configuration (Primary LLM)
# ====================================

# Ollama Base URL
# For local: http://localhost:11434
# For Docker: http://ollama:11434
# For remote: http://your-ollama-server:11434
OLLAMA_BASE_URL=http://localhost:11434

# Chat Model
# Options: llama3.2:3b, llama3.2:1b, llama3.1, llama3, phi3, mistral, etc.
# Smaller models (1b, 3b) are faster but less capable
# Larger models (70b) are more capable but slower
OLLAMA_MODEL=llama3.2:3b

# Embedding Model
# Default: nomic-embed-text (recommended for most use cases)
# Alternative: mxbai-embed-large, all-minilm
OLLAMA_EMBED_MODEL=nomic-embed-text

# Keep Alive Duration
# How long to keep the model loaded in memory
# Options: 5m, 10m, 30m, 1h
OLLAMA_KEEP_ALIVE=5m

# Context Window Size
# Number of tokens the model can process at once
# Options: 2048, 4096, 8192, 16384
OLLAMA_NUM_CTX=4096

# ====================================
# LLM Parameters
# ====================================

# Temperature (0.0 to 1.0)
# Lower = more focused and deterministic
# Higher = more creative and random
LLM_TEMP=0.7

# Max Output Tokens
# Maximum number of tokens in the response
LLM_MAXTOK=8192

# ====================================
# Database Configuration
# ====================================

# Database Mode
# Options: json, sqlite (json is simpler for deployment)
db_mode=json

# ====================================
# Text-to-Speech Configuration
# ====================================

# TTS Provider
# Options: edge (free, no API key), google, elevenlabs
TTS_PROVIDER=edge

# FFMPEG Path (required for audio processing)
FFMPEG_PATH=ffmpeg

# Edge TTS Voices
TTS_VOICE_EDGE=en-US-AvaNeural
TTS_VOICE_ALT_EDGE=en-US-AndrewNeural

# Google Cloud TTS (if using google provider)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json
# GOOGLE_CLOUD_PROJECT_ID=your-project-id
# TTS_VOICE_GOOGLE=en-US-Neural2-F
# TTS_VOICE_ALT_GOOGLE=en-US-Neural2-D

# ElevenLabs TTS (if using elevenlabs provider)
# ELEVEN_API_KEY=your-api-key
# ELEVEN_VOICE_A=voice-id-1
# ELEVEN_VOICE_B=voice-id-2

# ====================================
# Transcription Configuration
# ====================================

# Transcription Provider
# Options: whisper (local), assemblyai, google, openai
TRANSCRIPTION_PROVIDER=whisper

# AssemblyAI (if using assemblyai provider)
# ASSEMBLYAI_API_KEY=your-api-key

# ====================================
# Performance Tuning
# ====================================

# Enable/disable features for performance
# DISABLE_EMBEDDINGS=false
# DISABLE_VECTOR_SEARCH=false

# ====================================
# Deployment Notes
# ====================================
# 
# 1. Install Ollama: https://ollama.ai/
# 2. Pull your models:
#    ollama pull llama3.2:3b
#    ollama pull nomic-embed-text
# 3. Verify Ollama is running: curl http://localhost:11434
# 4. Update URLs for production domain
# 5. Choose appropriate model size for your hardware
# 6. Monitor memory usage (3b model ~2GB, 7b ~4GB, 70b ~40GB)
#
